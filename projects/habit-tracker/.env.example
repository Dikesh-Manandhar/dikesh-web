# Server Configuration
NODE_ENV=development
PORT=3000

# JWT Secret (generate a strong one: use `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`)
JWT_SECRET=your-secret-key-change-this

# CORS Origins (comma-separated, no spaces)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000

# MongoDB Connection String
# Local:     MONGODB_URI=mongodb://localhost:27017/habit_tracker
# Atlas:     MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/habit_tracker

# Cookie Security (set to true when using HTTPS in production)
COOKIE_SECURE=false

# =============================================================
# RENDER + MONGODB ATLAS (Production)
# =============================================================
# NODE_ENV=production
# PORT=3000
# JWT_SECRET=<generate-a-strong-secret>
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
# ALLOWED_ORIGINS=https://habit.dikeshmanandhar.com.np
# COOKIE_SECURE=true
